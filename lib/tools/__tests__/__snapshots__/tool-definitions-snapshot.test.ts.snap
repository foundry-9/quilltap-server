exports[`tool definitions: derived OpenAI parameters wardrobeTakeOff: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "operations": {
      "description": "An ordered list of take-off changes applied in sequence. Apply multiple removals in one call rather than calling the tool repeatedly.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "item_id": {
            "description": "The worn item to take off. Required for mode=remove (with item_title as a fallback). For a composite outfit, this filters the outfit out of every slot it covers. Items from the character's own wardrobe, the project, and Quilltap General all resolve.",
            "type": "string",
          },
          "item_title": {
            "description": "Fallback lookup by title (case-insensitive) when item_id is unknown.",
            "type": "string",
          },
          "mode": {
            "description": ""remove" (default) — take the named item off across every slot it covers; other layers in those slots stay. Pass a slot to restrict the removal to that one slot. "clear_slot" — empty one named slot entirely (requires slot).",
            "enum": [
              "remove",
              "clear_slot",
            ],
            "type": "string",
          },
          "slot": {
            "description": "Required for clear_slot. Optional for remove (restricts the removal to that single slot instead of every slot the item covers).",
            "enum": [
              "top",
              "bottom",
              "footwear",
              "accessories",
            ],
            "type": "string",
          },
        },
        "type": "object",
      },
      "minItems": 1,
      "type": "array",
    },
  },
  "required": [
    "operations",
  ],
  "type": "object",
}
`;


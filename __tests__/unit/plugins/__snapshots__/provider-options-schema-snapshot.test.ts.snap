exports[`Provider options schemas Anthropic exposes an options schema 1`] = `
{
  "groups": [
    {
      "fields": [
        {
          "default": false,
          "key": "enableCacheBreakpoints",
          "label": "Enable Prompt Caching",
          "type": "boolean",
        },
        {
          "default": "system_and_long_context",
          "enumValues": [
            {
              "label": "System message only",
              "value": "system_only",
            },
            {
              "label": "System + tools + conversation (recommended)",
              "value": "system_and_long_context",
            },
          ],
          "key": "cacheStrategy",
          "label": "Cache Strategy",
          "showIf": {
            "equals": true,

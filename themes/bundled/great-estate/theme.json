  "version": "1.0.2",
  "author": "Foundry-9 LLC",
  "license": "MIT",
  "supportsDarkMode": true,
  "tags": [
    "great-estate",
    "gold",
    "mahogany",
    "warm",
    "elegant",
    "manor"
  ],

{
  "name": "@foundry-9/quilltap",
  "version": "4.4.0-dev.213",
  "private": true,
  "author": {
    "name": "Charles Sebold",
    "email": "charles.sebold@foundry-9.com",
    "url": "https://foundry-9.com"
  },
  "description": "Self-hosted AI workspace for writers, worldbuilders, and roleplayers",
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foundry-9/quilltap-server.git"
  },
  "scripts": {
    "build": "npm run build:next",
    "build:docker": "tsx scripts/build-push-docker.ts",
    "build:next": "npm run build:plugins && next build",
    "build:package": "tsx scripts/build-quilltap-package.ts",
    "build:standalone": "tsx scripts/build-standalone-tarball.ts",
    "build:plugins": "tsx scripts/build-plugins.ts",
    "deploy:dev": "./cicd/deploy.sh",
    "dev": "tsx server.ts",
    "dev:next": "next dev --turbopack",
    "devssl": "next dev --experimental-https --experimental-https-key ./certs/localhost-key.pem --experimental-https-cert ./certs/localhost.pem",
    "generate:schemas": "tsx scripts/generate-plugin-manifest-schema.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "oneoff:cleanup-old-files-v1.6": "tsx scripts/cleanup-old-files.ts",
    "oneoff:rebuild-vector-indices": "tsx scripts/rebuild-vector-indices.ts",
    "oneoff:theme-convert-v2.8": "tsx scripts/convert-theme-to-module.ts",
    "oneoff:theme-convert-v2.8:all": "tsx scripts/convert-theme-to-module.ts --all",
    "oneoff:theme-convert-v2.8:dry-run": "tsx scripts/convert-theme-to-module.ts --all --dry-run",
    "postinstall": "node scripts/fix-node-pty-permissions.js",
    "start": "NODE_ENV=production tsx server.ts",
    "start:docker": "tsx scripts/start-quilltap-docker.ts",
    "stop:docker": "docker stop quilltap && docker rm quilltap",
    "test": "cross-env LOG_LEVEL=error npm run test:all",
    "test:all": "cross-env LOG_LEVEL=error jest && cross-env LOG_LEVEL=error jest --config jest.integration.config.ts",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "cross-env LOG_LEVEL=error jest --config jest.integration.config.ts",
    "test:unit": "cross-env LOG_LEVEL=error jest",
    "test:watch": "jest --watch",
    "update:npm": "./scripts/upgrade-dependencies.sh",
    "update:version": "./scripts/update_version.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/clipboard": "^0.43.0",
    "@lexical/code": "^0.43.0",
    "@lexical/history": "^0.43.0",
    "@lexical/link": "^0.43.0",
    "@lexical/list": "^0.43.0",
    "@lexical/markdown": "^0.43.0",
    "@lexical/react": "^0.43.0",
    "@lexical/rich-text": "^0.43.0",
    "@lexical/selection": "^0.43.0",
    "@lexical/table": "^0.43.0",
    "@msgpack/msgpack": "^3.1.3",
    "@quilltap/plugin-types": "^2.3.2",
    "@quilltap/plugin-utils": "^2.2.7",
    "@quilltap/theme-storybook": "^1.0.34",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/yauzl": "^2.10.3",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.9.0",
    "chokidar": "^5.0.0",
    "create-quilltap-theme": "^2.0.9",
    "jest-fetch-mock": "^3.0.3",
    "lexical": "^0.43.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "semver": "^7.8.0",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "tar": "^7.5.15",
    "unified": "^11.0.5",
    "ws": "^8.20.1",
    "yaml": "^2.9.0",
    "yauzl": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@openrouter/sdk": "^0.12.35",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@vitest/mocker": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "glob": "^12.0.0",
    "cookie": "^0.7.0",
    "pdfjs-dist": "$pdfjs-dist",
    "@napi-rs/canvas": "^0.1.100"
  }
}

{
  "$schema": "../qtap-plugin-template/schemas/plugin-manifest.schema.json",
  "name": "qtap-plugin-storage-s3",
  "title": "S3 File Storage",
  "description": "Store files in Amazon S3 or S3-compatible storage (MinIO, DigitalOcean Spaces, etc.)",
  "version": "1.0.0",
  "author": {
    "name": "Foundry-9 LLC",
    "email": "charles.sebold@foundry-9.com",
    "url": "https://foundry-9.com"
  },
  "license": "MIT",
  "compatibility": {
    "quilltapVersion": ">=2.5.0",
    "nodeVersion": ">=18.0.0"
  },
  "capabilities": ["FILE_BACKEND"],
  "category": "STORAGE",
  "main": "index.js",
  "typescript": true,
  "enabledByDefault": true,
  "requiresRestart": true,
  "status": "STABLE",
  "keywords": ["s3", "aws", "minio", "storage", "file", "cloud"],
  "fileBackendConfig": {
    "backendId": "s3",
    "displayName": "Amazon S3 / S3-Compatible",
    "configFields": [
      { "name": "bucket", "label": "Bucket Name", "type": "string", "required": true },
      { "name": "region", "label": "Region", "type": "string", "required": false, "defaultValue": "us-east-1" },
      { "name": "endpoint", "label": "Endpoint URL (for MinIO, etc.)", "type": "string", "required": false },
      { "name": "accessKey", "label": "Access Key ID", "type": "secret", "required": false },
      { "name": "secretKey", "label": "Secret Access Key", "type": "secret", "required": false },
      { "name": "pathPrefix", "label": "Path Prefix", "type": "string", "required": false },
      { "name": "forcePathStyle", "label": "Force Path Style", "type": "boolean", "required": false, "defaultValue": false },
      { "name": "publicUrl", "label": "Public/CDN URL", "type": "string", "required": false }
    ]
  },
  "permissions": {
    "network": ["*"],
    "userData": false,
    "database": false
  }
}

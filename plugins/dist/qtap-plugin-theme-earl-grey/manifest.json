{
  "$schema": "../qtap-plugin-template/schemas/plugin-manifest.schema.json",
  "name": "qtap-plugin-theme-earl-grey",
  "title": "Earl Grey",
  "description": "A high-contrast dark theme inspired by modern AI chat interfaces, with pure black sidebar, charcoal main area, and clean minimal styling",
  "version": "1.3.3",
  "author": {
    "name": "Foundry-9 LLC",
    "email": "charles.sebold@foundry-9.com",
    "url": "https://foundry-9.com"
  },
  "license": "MIT",
  "main": "index.js",
  "compatibility": {
    "quilltapVersion": ">=2.2.0",
    "nodeVersion": ">=18.0.0"
  },
  "capabilities": [
    "THEME"
  ],
  "category": "THEME",
  "typescript": true,
  "frontend": "NONE",
  "styling": "CSS_MODULES",
  "enabledByDefault": true,
  "status": "STABLE",
  "keywords": [
    "theme",
    "earl-grey",
    "dark",
    "slate",
    "blue",
    "elegant",
    "sophisticated"
  ],
  "themeConfig": {
    "tokensPath": "tokens.json",
    "stylesPath": "styles.css",
    "supportsDarkMode": true,
    "previewImage": "preview.png",
    "tags": [
      "earl-grey",
      "dark",
      "minimal",
      "high-contrast",
      "modern"
    ],
    "fonts": [
      {
        "family": "Rethink Sans",
        "src": "fonts/RethinkSans-latin.woff2",
        "weight": "400 700",
        "style": "normal",
        "display": "swap"
      },
      {
        "family": "Rethink Sans",
        "src": "fonts/RethinkSans-latin-ext.woff2",
        "weight": "400 700",
        "style": "normal",
        "display": "swap"
      }
    ],
    "useModule": true
  },
  "permissions": {
    "fileSystem": [],
    "network": [],
    "database": false,
    "userData": false
  }
}

{
  "$schema": "../qtap-plugin-template/schemas/plugin-manifest.schema.json",
  "name": "qtap-plugin-theme-ocean",
  "title": "Ocean",
  "description": "A quirky, childlike theme evoking the serenity of life underwater in a beautiful coral reef. Features vibrant sea life colors, bubbly rounded corners, glass-effect panels, and playful animations.",
  "version": "1.2.5",
  "author": {
    "name": "Foundry-9 LLC",
    "email": "charles.sebold@foundry-9.com",
    "url": "https://foundry-9.com"
  },
  "license": "MIT",
  "main": "index.js",
  "compatibility": {
    "quilltapVersion": ">=2.2.0",
    "nodeVersion": ">=18.0.0"
  },
  "capabilities": [
    "THEME"
  ],
  "category": "THEME",
  "typescript": true,
  "frontend": "NONE",
  "styling": "CSS_MODULES",
  "enabledByDefault": true,
  "status": "STABLE",
  "keywords": [
    "theme",
    "ocean",
    "underwater",
    "coral reef",
    "playful",
    "childlike",
    "whimsical",
    "teal",
    "coral",
    "light"
  ],
  "themeConfig": {
    "tokensPath": "tokens.json",
    "stylesPath": "styles.css",
    "supportsDarkMode": true,
    "previewImage": "preview.png",
    "tags": [
      "ocean",
      "underwater",
      "playful",
      "coral reef",
      "whimsical"
    ],
    "fonts": [
      {
        "family": "Nunito",
        "src": "fonts/Nunito-Regular.woff2",
        "weight": "400",
        "style": "normal",
        "display": "swap"
      },
      {
        "family": "Nunito",
        "src": "fonts/Nunito-Bold.woff2",
        "weight": "700",
        "style": "normal",
        "display": "swap"
      },
      {
        "family": "Space Mono",
        "src": "fonts/SpaceMono-Regular.ttf",
        "weight": "400",
        "style": "normal",
        "display": "swap"
      }
    ],
    "useModule": true
  },
  "permissions": {
    "fileSystem": [],
    "network": [],
    "database": false,
    "userData": false
  }
}

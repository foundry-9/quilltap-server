import * as esbuild from 'esbuild';

await esbuild.build({
  entryPoints: ['index.ts'],
  bundle: true,
  platform: 'node',
  target: 'node18',
  format: 'cjs',
  outfile: 'index.js',
  external: ['@quilltap/plugin-utils'],
  sourcemap: false,
  minify: false,
});

console.log('Build complete: index.js');

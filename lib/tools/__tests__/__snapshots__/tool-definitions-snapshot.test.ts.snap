exports[`tool definitions: derived OpenAI parameters docGrep: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "case_sensitive": {
      "default": false,
      "description": "Case-sensitive matching. Default is case-insensitive.",
      "type": "boolean",
    },
    "context_lines": {
      "default": 0,
      "description": "Number of lines of context to include before and after each match.",
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer",
    },
    "is_regex": {
      "default": false,
      "description": "Treat query as a regular expression rather than literal text.",
      "type": "boolean",
    },
    "max_results": {
      "default": 100,
      "description": "Maximum number of matching lines to return.",
      "maximum": 9007199254740991,
      "minimum": 1,
      "type": "integer",
    },
    "mount_point": {
      "description": "Optional: restrict search to a specific mount point (name or ID). Pass "self" to search only your own character vault. Without this, searches all mounted points.",
      "type": "string",
    },
    "normalize_diacritics": {
      "default": true,
      "description": "Normalize Unicode diacritics for matching (e.g., "Nimue" matches "Nimuë"). Default is true.",
      "type": "boolean",
    },
    "path": {
      "description": "Optional: restrict search to a specific file or folder path. If a folder, searches recursively.",
      "type": "string",
    },
    "query": {
      "description": "Search string or regex pattern to find.",
      "type": "string",
    },
    "uri": {
      "description": "A qtap:// URI addressing the target, e.g. "qtap://self/Notes/today.md". When provided, it supersedes scope/mount_point/path.",
      "type": "string",
    },
  },
  "required": [
    "query",
  ],
  "type": "object",
}
`;

exports[`tool definitions: derived OpenAI parameters docInsertText: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "content": {
      "description": "Text to insert at the specified position.",
      "type": "string",
    },
    "mount_point": {
      "description": "Mount point name. Required when scope is "document_store". The reserved value "self" addresses your own character vault.",
      "type": "string",
    },
    "normalize_diacritics": {
      "default": true,
      "description": "Normalize Unicode diacritics when matching anchor text (e.g., "Nimue" matches "Nimuë"). Default is true.",
      "type": "boolean",
    },
    "path": {
      "description": "Relative path to the file within the selected scope.",
      "type": "string",
    },
    "position": {
      "additionalProperties": false,
      "description": "Insertion position. Must specify exactly one of: before (string), after (string), or at ("start"|"end").",
      "properties": {
        "after": {
          "description": "Insert text after this anchor text (must be unique in file).",
          "type": "string",
        },
        "at": {
          "description": "Insert at the start or end of the file.",
          "enum": [
            "start",
            "end",
          ],
          "type": "string",
        },
        "before": {
          "description": "Insert text before this anchor text (must be unique in file).",
          "type": "string",
        },
      },
      "type": "object",
    },
    "scope": {
      "default": "document_store",
      "description": "The file source scope. "document_store" operates on mounted document stores, "project" on project files, "general" on general files.",
      "enum": [
        "document_store",
        "project",
        "general",
      ],
      "type": "string",
    },
    "uri": {
      "description": "A qtap:// URI addressing the target, e.g. "qtap://self/Notes/today.md". When provided, it supersedes scope/mount_point/path.",
      "type": "string",
    },
  },
  "required": [
    "position",
    "content",
  ],
  "type": "object",
}
`;


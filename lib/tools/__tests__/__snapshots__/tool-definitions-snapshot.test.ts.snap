exports[`tool definitions: derived OpenAI parameters docCloseDocument: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "mount_point": {
      "description": "Mount point of the target document (for document_store scope), matched alongside path when several documents are open.",
      "type": "string",
    },
    "path": {
      "description": "Which open document to close, by file path. Optional when only one document is open; omit to close the most recently opened document.",
      "type": "string",
    },
    "reason": {
      "description": "Optional reason for closing the document. Shown to the user as a system note.",
      "type": "string",
    },
    "scope": {
      "description": "Scope of the target document, matched alongside path/mount_point when several documents are open.",
      "enum": [
        "project",
        "document_store",
        "general",
      ],
      "type": "string",
    },
  },
  "type": "object",
}
`;

exports[`tool definitions: derived OpenAI parameters docCopyFile: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "dest_mount_point": {
      "description": "Name (or ID) of the document store to copy the file into. Pass "self" for your own character vault. Must be different from source_mount_point.",
      "minLength": 1,
      "type": "string",
    },
    "dest_path": {
      "description": "Destination path within the destination document store. If this path already exists as a directory, the file is dropped into it with the source filename. Otherwise it is treated as the full path with filename. Use "" or "." to copy to the root of the destination store.",
      "type": "string",
    },
    "dest_uri": {
      "description": "A qtap:// URI for the destination, e.g. "qtap://Shared/Notes/today.md". When provided, it supersedes dest_mount_point/dest_path.",
      "type": "string",
    },
    "source_mount_point": {
      "description": "Name (or ID) of the document store to copy the file from. Pass "self" for your own character vault.",
      "minLength": 1,
      "type": "string",
    },
    "source_path": {
      "description": "Relative path to the source file within the source document store.",
      "minLength": 1,
      "type": "string",
    },
    "source_uri": {
      "description": "A qtap:// URI for the source document, e.g. "qtap://self/Notes/today.md". When provided, it supersedes source_mount_point/source_path.",
      "type": "string",
    },
  },
  "type": "object",
}
`;


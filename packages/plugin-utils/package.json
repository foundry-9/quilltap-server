{
  "name": "@quilltap/plugin-utils",
  "version": "2.2.3",
  "description": "Utility functions for Quilltap plugin development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.mjs",
      "require": "./dist/tools/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.mjs",
      "require": "./dist/logging/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.js"
    },
    "./system-prompts": {
      "types": "./dist/system-prompts/index.d.ts",
      "import": "./dist/system-prompts/index.mjs",
      "require": "./dist/system-prompts/index.js"
    },
    "./host-rewrite": {
      "types": "./dist/host-rewrite.d.ts",
      "import": "./dist/host-rewrite.mjs",
      "require": "./dist/host-rewrite.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@quilltap/plugin-types": "^2.3.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "@quilltap/plugin-types": {
      "optional": false
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "openai": "^6.34.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "quilltap",
    "plugin",
    "utils",
    "utilities",
    "llm",
    "ai",
    "provider",
    "tools",
    "logging"
  ],
  "author": {
    "name": "Foundry-9 LLC",
    "url": "https://github.com/foundry-9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foundry-9/quilltap-server.git",
    "directory": "packages/plugin-utils"
  },
  "homepage": "https://github.com/foundry-9/quilltap-server/tree/main/packages/plugin-utils#readme",
  "bugs": {
    "url": "https://github.com/foundry-9/quilltap-server/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

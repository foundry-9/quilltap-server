          {
            "id": "b1a0c001-1001-4001-a001-100000000003",
            "characterId": "a42c02d7-90b8-49da-b7fa-c5f31894afd7",
            "title": "Brass Key Pendant",
            "description": "A small brass key hanging from a simple cord around the neck — his only ornament. A symbol of both access and farewell, resting against his chest.",
            "types": ["accessories"],

      {
        "id": "ecda69f7-0ebf-4302-9e87-e7db1f170791",
        "characterId": "f11db2bc-8cfe-4beb-a1b8-91f4c4ba9f23",
        "content": "Riya remembers being teased in college for her mixed dialect—English wrapped in Tamil lilt—but she learned to wield it as her personal code, proof that clarity can carry accent and invention together.",
        "summary": "Embraced her hybrid accent as creative signature instead of flaw.",

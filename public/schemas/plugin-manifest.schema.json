{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^(@[a-z0-9-]+\\/)?qtap-plugin-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?(\\+[a-zA-Z0-9.-]+)?$"
    },
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      ]
    },
    "license": {
      "default": "MIT",
      "type": "string"
    },
    "main": {
      "default": "index.js",
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "directory": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false
        }
      ]
    },
    "bugs": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
            }
          },
          "required": [
            "url"
          ],
          "additionalProperties": false
        }
      ]
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "quilltapVersion": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
        },
        "quilltapMaxVersion": {
          "type": "string",
          "pattern": "^<=?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
        },
        "nodeVersion": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+$"
        }
      },
      "required": [
        "quilltapVersion"
      ],
      "additionalProperties": false
    },
    "requires": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "peerDependencies": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "capabilities": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "CHAT_COMMANDS",
          "MESSAGE_PROCESSORS",
          "UI_COMPONENTS",
          "DATA_STORAGE",
          "API_ROUTES",
          "AUTH_METHODS",
          "WEBHOOKS",
          "BACKGROUND_TASKS",
          "CUSTOM_MODELS",
          "FILE_HANDLERS",
          "NOTIFICATIONS",
          "BACKEND_INTEGRATIONS",
          "LLM_PROVIDER",
          "IMAGE_PROVIDER",
          "EMBEDDING_PROVIDER",
          "THEME",
          "DATABASE_BACKEND",
          "UPGRADE_MIGRATION",
          "ROLEPLAY_TEMPLATE",
          "TOOL_PROVIDER",
          "SEARCH_PROVIDER",
          "MODERATION_PROVIDER"
        ]
      }
    },
    "functionality": {
      "type": "object",
      "properties": {
        "providesChatCommands": {
          "default": false,
          "type": "boolean"
        },
        "providesMessageProcessors": {
          "default": false,
          "type": "boolean"
        },
        "providesUIComponents": {
          "default": false,
          "type": "boolean"
        },
        "providesDataStorage": {
          "default": false,
          "type": "boolean"
        },
        "providesAPIRoutes": {
          "default": false,
          "type": "boolean"
        },
        "providesAuthenticationMethods": {
          "default": false,
          "type": "boolean"
        },
        "providesWebhooks": {
          "default": false,
          "type": "boolean"
        },
        "providesBackgroundTasks": {
          "default": false,
          "type": "boolean"
        },
        "providesCustomModels": {
          "default": false,
          "type": "boolean"
        },
        "providesFileHandlers": {
          "default": false,
          "type": "boolean"
        },
        "providesNotifications": {
          "default": false,
          "type": "boolean"
        },
        "providesBackendIntegrations": {
          "default": false,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "frontend": {
      "default": "REACT",
      "type": "string",
      "enum": [
        "REACT",
        "PREACT",
        "VUE",
        "SVELTE",
        "NONE"
      ]
    },
    "styling": {
      "default": "TAILWIND",
      "type": "string",
      "enum": [
        "TAILWIND",
        "BOOTSTRAP",
        "MATERIAL_UI",
        "CSS_MODULES",
        "STYLED_COMPONENTS",
        "NONE"
      ]
    },
    "typescript": {
      "default": true,
      "type": "boolean"
    },
    "hooks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "handler": {
            "type": "string"
          },
          "priority": {
            "default": 50,
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "enabled": {
            "default": true,
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "handler",
          "priority",
          "enabled"
        ],
        "additionalProperties": false
      }
    },
    "apiRoutes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^\\/api\\/"
          },
          "methods": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "GET",
                "POST",
                "PUT",
                "PATCH",
                "DELETE"
              ]
            }
          },
          "handler": {
            "type": "string"
          },
          "requiresAuth": {
            "default": true,
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "methods",
          "handler",
          "requiresAuth"
        ],
        "additionalProperties": false
      }
    },
    "components": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "path": {
            "type": "string"
          },
          "slots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "propsSchema": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "id",
          "name",
          "path"
        ],
        "additionalProperties": false
      }
    },
    "models": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "schemaPath": {
            "type": "string"
          },
          "collectionName": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-_]*$"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "schemaPath",
          "collectionName"
        ],
        "additionalProperties": false
      }
    },
    "configSchema": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "number",
              "boolean",
              "select",
              "textarea",
              "password",
              "url",
              "email"
            ]
          },
          "default": {},
          "required": {
            "default": false,
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "value": {}
              },
              "required": [
                "label",
                "value"
              ],
              "additionalProperties": false
            }
          },
          "pattern": {
            "type": "string"
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        },
        "required": [
          "key",
          "label",
          "type",
          "required"
        ],
        "additionalProperties": false
      }
    },
    "defaultConfig": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "providerConfig": {
      "type": "object",
      "properties": {
        "providerName": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "abbreviation": {
          "type": "string",
          "minLength": 2,
          "maxLength": 4,
          "pattern": "^[A-Z0-9]+$"
        },
        "colors": {
          "type": "object",
          "properties": {
            "bg": {
              "type": "string",
              "minLength": 1
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "icon": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "bg",
            "text",
            "icon"
          ],
          "additionalProperties": false
        },
        "requiresApiKey": {
          "default": true,
          "type": "boolean"
        },
        "requiresBaseUrl": {
          "default": false,
          "type": "boolean"
        },
        "apiKeyLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "baseUrlLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "baseUrlDefault": {
          "type": "string",
          "format": "uri"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "chat": {
              "default": true,
              "type": "boolean"
            },
            "imageGeneration": {
              "default": false,
              "type": "boolean"
            },
            "embeddings": {
              "default": false,
              "type": "boolean"
            },
            "webSearch": {
              "default": false,
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "attachmentSupport": {
          "type": "object",
          "properties": {
            "supported": {
              "default": false,
              "type": "boolean"
            },
            "mimeTypes": {
              "default": [],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "supported",
            "mimeTypes"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "providerName",
        "displayName",
        "description",
        "abbreviation",
        "colors",
        "requiresApiKey",
        "requiresBaseUrl"
      ],
      "additionalProperties": false
    },
    "authProviderConfig": {
      "type": "object",
      "properties": {
        "providerId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "requiredEnvVars": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optionalEnvVars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "buttonColor": {
          "type": "string"
        },
        "buttonTextColor": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "providerId",
        "displayName",
        "requiredEnvVars"
      ],
      "additionalProperties": false
    },
    "themeConfig": {
      "type": "object",
      "properties": {
        "tokensPath": {
          "default": "tokens.json",
          "description": "Path to theme tokens JSON file",
          "type": "string"
        },
        "stylesPath": {
          "description": "Path to component override CSS file",
          "type": "string"
        },
        "supportsDarkMode": {
          "default": true,
          "description": "Whether theme provides dark mode colors",
          "type": "boolean"
        },
        "previewImage": {
          "description": "Theme preview image for theme picker",
          "type": "string"
        },
        "extendsTheme": {
          "description": "Plugin name of theme to extend",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "tags": {
          "description": "Tags for theme discovery",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fonts": {
          "description": "Custom fonts to load",
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "family": {
                "type": "string",
                "minLength": 1,
                "description": "Font family name"
              },
              "src": {
                "type": "string",
                "minLength": 1,
                "description": "Font file path relative to plugin"
              },
              "weight": {
                "default": "400",
                "description": "Font weight",
                "type": "string"
              },
              "style": {
                "default": "normal",
                "description": "Font style",
                "type": "string"
              },
              "display": {
                "default": "swap",
                "type": "string",
                "enum": [
                  "auto",
                  "block",
                  "swap",
                  "fallback",
                  "optional"
                ]
              }
            },
            "required": [
              "family",
              "src",
              "weight",
              "style",
              "display"
            ],
            "additionalProperties": false
          }
        },
        "useModule": {
          "description": "Use module-based self-contained loading",
          "default": true,
          "type": "boolean"
        },
        "subsystems": {
          "description": "Override Foundry subsystem names, descriptions, and images",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "thumbnail": {
                "type": "string"
              },
              "backgroundImage": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": [
        "tokensPath",
        "supportsDarkMode"
      ],
      "additionalProperties": false
    },
    "roleplayTemplateConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Template display name"
        },
        "description": {
          "description": "Template description",
          "type": "string",
          "maxLength": 500
        },
        "systemPrompt": {
          "type": "string",
          "minLength": 1,
          "description": "System prompt with formatting instructions"
        },
        "tags": {
          "description": "Tags for categorization",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "annotationButtons": {
          "description": "Formatting toolbar buttons",
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50,
                "description": "Full name for tooltip"
              },
              "abbrev": {
                "type": "string",
                "minLength": 1,
                "maxLength": 10,
                "description": "Short label for button"
              },
              "prefix": {
                "type": "string",
                "description": "Opening delimiter"
              },
              "suffix": {
                "type": "string",
                "description": "Closing delimiter"
              }
            },
            "required": [
              "label",
              "abbrev",
              "prefix",
              "suffix"
            ],
            "additionalProperties": false
          }
        },
        "renderingPatterns": {
          "description": "Message content rendering patterns",
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "minLength": 1,
                "description": "Regex pattern string"
              },
              "className": {
                "type": "string",
                "minLength": 1,
                "description": "CSS class name"
              },
              "flags": {
                "description": "Regex flags",
                "type": "string"
              }
            },
            "required": [
              "pattern",
              "className"
            ],
            "additionalProperties": false
          }
        },
        "dialogueDetection": {
          "description": "Dialogue paragraph detection",
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "openingChars": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Opening quote characters"
                },
                "closingChars": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Closing quote characters"
                },
                "className": {
                  "type": "string",
                  "minLength": 1,
                  "description": "CSS class name"
                }
              },
              "required": [
                "openingChars",
                "closingChars",
                "className"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "systemPrompt"
      ],
      "additionalProperties": false
    },
    "toolConfig": {
      "type": "object",
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Tool name for LLM function calls"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Display name for UI"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000,
          "description": "Description for LLM"
        },
        "requiresConfiguration": {
          "default": false,
          "description": "Whether user must configure before use",
          "type": "boolean"
        },
        "enabledByDefault": {
          "default": true,
          "description": "Whether tool is enabled by default",
          "type": "boolean"
        }
      },
      "required": [
        "toolName",
        "displayName",
        "description",
        "requiresConfiguration",
        "enabledByDefault"
      ],
      "additionalProperties": false
    },
    "searchProviderConfig": {
      "type": "object",
      "properties": {
        "providerName": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "abbreviation": {
          "type": "string",
          "minLength": 2,
          "maxLength": 4,
          "pattern": "^[A-Z0-9]+$"
        },
        "colors": {
          "type": "object",
          "properties": {
            "bg": {
              "type": "string",
              "minLength": 1
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "icon": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "bg",
            "text",
            "icon"
          ],
          "additionalProperties": false
        },
        "requiresApiKey": {
          "default": true,
          "type": "boolean"
        },
        "apiKeyLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "requiresBaseUrl": {
          "default": false,
          "type": "boolean"
        },
        "baseUrlDefault": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "providerName",
        "displayName",
        "description",
        "abbreviation",
        "colors",
        "requiresApiKey",
        "requiresBaseUrl"
      ],
      "additionalProperties": false
    },
    "moderationProviderConfig": {
      "type": "object",
      "properties": {
        "providerName": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "abbreviation": {
          "type": "string",
          "minLength": 2,
          "maxLength": 4,

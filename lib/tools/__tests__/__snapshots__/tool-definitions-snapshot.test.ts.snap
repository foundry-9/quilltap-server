exports[`tool definitions: derived OpenAI parameters imageGeneration: parameters snapshot 1`] = `
{
  "additionalProperties": false,
  "properties": {
    "aspectRatio": {
      "description": "Advanced, provider-dependent: an exact aspect ratio honoured only by aspect-ratio providers (e.g. Google, Grok, OpenRouter). Prefer \`orientation\`.",
      "enum": [
        "1:1",
        "3:4",
        "4:3",
        "9:16",
        "16:9",
      ],
      "type": "string",
    },
    "count": {
      "default": 1,
      "description": "Number of images to generate. Default is 1.",
      "maximum": 10,
      "minimum": 1,
      "type": "integer",
    },
    "negativePrompt": {
      "description": "Optional description of what to avoid in the image. Example: "blurry, low quality, watermark"",
      "maxLength": 1000,
      "type": "string",
    },
    "orientation": {
      "description": "PREFERRED way to control image shape. The system maps this onto whatever each provider supports (a concrete size, an aspect ratio, or prompt wording), so it works everywhere. "portrait" = taller than wide, "landscape" = wider than tall, "square" = 1:1. Use this instead of \`size\`/\`aspectRatio\` unless you have a specific reason not to.",
      "enum": [
        "portrait",
        "landscape",
        "square",
      ],
      "type": "string",
    },
    "prompt": {
      "description": "A detailed description of the image to generate. Be specific about style, composition, colors, mood, lighting, and any other visual elements.

**CRITICAL: Always use {{placeholders}} for people - the system expands these with physical descriptions:**
- {{me}}, {{I}}, or {{char}} = yourself (the character/assistant)
- {{user}} = the person you are talking to (the user character)
- {{CharacterName}} = any character by name

**When depicting BOTH yourself AND the user together, you MUST use BOTH placeholders.** Do NOT describe appearances directly - use placeholders so the system can insert the correct descriptions.

Good: "{{me}} and {{user}} sitting together in a cozy café, warm lighting"
Good: "{{char}} handing a gift to {{user}} in a garden setting"
Bad: "A woman with brown hair sitting with a man" (missing placeholders!)",
      "maxLength": 4000,
      "minLength": 1,
      "type": "string",
    },
    "quality": {
      "default": "standard",
      "description": "Image quality. "standard" for regular quality (faster, lower cost). "hd" produces finer details and greater consistency (slower, higher cost).",
      "enum": [
        "standard",
        "hd",
      ],
      "type": "string",
    },
    "size": {
      "default": "1024x1024",
      "description": "Advanced, provider-dependent: an exact pixel size honoured only by some providers (e.g. OpenAI). Most providers ignore it. Prefer \`orientation\`.",
      "enum": [
        "1024x1024",
        "1792x1024",
        "1024x1792",
      ],
      "type": "string",
    },
    "style": {
      "default": "vivid",
      "description": "Image style. "vivid" for dramatic, hyper-real, detailed images with vibrant colors. "natural" for more realistic, understated, less exaggerated images.",
      "enum": [
        "vivid",
        "natural",
      ],
      "type": "string",
    },
  },
  "required": [
    "prompt",
  ],
  "type": "object",
}
`;


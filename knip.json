{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "scripts/*.ts",
    "migrations/*.ts",
    "lib/database/index.ts",
    "lib/chat/context/index.ts"
  ],
  "project": [
    "**/*.{ts,tsx}",
    "!packages/**",
    "!plugins/**"
  ],
  "ignore": [
    "packages/**",
    "plugins/**",
    "migrations/lib/**",
    "lib/background-jobs/child/child-entry.ts",
    "**/*.d.ts"
  ],
  "ignoreDependencies": [
    "@types/*",
    "ts-node",
    "@vitest/mocker",
    "create-quilltap-theme",
    "esbuild",
    "better-sqlite3-multiple-ciphers",
    "@anthropic-ai/sdk"
  ],
  "ignoreBinaries": [
    "ps",
    "tasklist",
    "du"
  ]
}

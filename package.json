{
  "name": "quilltap",
  "version": "2.7.0-dev.49",
  "private": true,
  "author": {
    "name": "Charles Sebold",
    "email": "charles.sebold@foundry-9.com",
    "url": "https://foundry-9.com"
  },
  "description": "A chat client application for hosted AI models designed for role play",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/foundry-9/quilltap.git"
  },
  "scripts": {
    "dev": "next dev",
    "devssl": "next dev --experimental-https --experimental-https-key ./certs/localhost-key.pem --experimental-https-cert ./certs/localhost.pem",
    "build": "npm run build:plugins && next build",
    "build:plugins": "tsx scripts/build-plugins.ts",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "LOG_LEVEL=error npm run test:all",
    "test:unit": "LOG_LEVEL=error jest",
    "test:integration": "LOG_LEVEL=error jest --config jest.integration.config.ts",
    "test:all": "LOG_LEVEL=error jest && LOG_LEVEL=error jest --config jest.integration.config.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "migrate-files": "tsx scripts/migrate-files.ts",
    "migrate-files:dry-run": "tsx scripts/migrate-files.ts --dry-run",
    "consolidate-images": "tsx scripts/consolidate-images.ts",
    "consolidate-images:dry-run": "tsx scripts/consolidate-images.ts --dry-run",
    "cleanup-old-files": "tsx scripts/cleanup-old-files.ts",
    "generate:schemas": "tsx scripts/generate-plugin-manifest-schema.ts",
    "deploy:dev": "./cicd/deploy.sh",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "theme:convert": "tsx scripts/convert-theme-to-module.ts",
    "theme:convert:all": "tsx scripts/convert-theme-to-module.ts --all",
    "theme:convert:dry-run": "tsx scripts/convert-theme-to-module.ts --all --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
    "@quilltap/plugin-types": "^1.5.0",
    "@quilltap/plugin-utils": "^1.2.0",
    "@tanstack/react-virtual": "^3.13.15",
    "@types/sharp": "^0.31.1",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "arctic": "^3.7.0",
    "bcrypt": "^6.0.0",
    "jest-fetch-mock": "^3.0.3",
    "jose": "^6.1.3",
    "mongodb": "^7.0.0",
    "next": "^16.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.15.0",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@openrouter/sdk": "^0.3.10",
    "@playwright/test": "^1.49.0",
    "@storybook/nextjs": "^10.1.11",
    "@storybook/react": "^10.1.11",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "~22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/speakeasy": "^2.0.10",
    "@vitest/mocker": "^4.0.16",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.0",
    "storybook": "^10.1.11",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "overrides": {
    "glob": "^12.0.0",
    "cookie": "^0.7.0"
  }
}
